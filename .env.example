# Core Meta App
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Entities
META_PAGE_ID=
META_IG_USER_ID=
META_AD_ACCOUNT_ID=act_xxxxxxx

# App behaviour
DEFAULT_POSTING_TIMEZONE=Australia/Brisbane
DEFAULT_AD_RADIUS_KM=40
DEFAULT_AD_AGE_MIN=30
DEFAULT_AD_AGE_MAX=65
DEFAULT_AD_DAILY_BUDGET_AUD=10

# Scheduler (MCP process)
# SCHEDULER_ENABLED=false
# SCHEDULER_INTERVAL_MS=45000
# SCHEDULER_STALE_PROCESSING_MS=900000

# SCRAPING_ENABLED=true — required for scheduled daily competitor scrape (`startCompetitorScrapeScheduler`).
# Supplier website/social scans (`summarize_supplier_updates`) run by default; set SCRAPING_ENABLED=false to disable all outbound scraping.

# Supplier email HTTP upload (health server)
# UPLOAD_EMAIL_API_ENABLED=false
